VITE_GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/e/your-sheet-id/pub?output=csv
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwudP3f_YU2rA7CbGMO8XfeJPHABuKsaISQQgCfTQQfk4ccbNV_Ep_Vdhsh61V_BMmI/exec

# ─── Identidade desta instância ───────────────────────────────────────────────
# VITE_SUBDOMAIN deve bater com o ID do documento em /imobiliarias/ no Firestore
# Exemplo: se o documento é /imobiliarias/imobi, coloque imobi aqui.
# Cada deploy de imobiliária tem seu próprio valor — nunca compartilhe o .env.
VITE_SUBDOMAIN=imobi
 
# URL base do painel Next.js (sem barra no final)
# Em dev local: http://localhost:3000
# Em produção: https://painel.seudominio.com.br
VITE_API_URL=https://painel.seudominio.com.br
 
# ─── Site Configuration ───────────────────────────────────────────────────────
VITE_SITE_NAME=ImobiSheet
VITE_SITE_URL=https://imobisheet.com
 
# ─── Contact Configuration ────────────────────────────────────────────────────
VITE_WHATSAPP_NUMBER=5511999999999